Cell[TextData[{
 StyleBox["Code for determining the vertices, edges, and faces of the \
four-dimensional polytope studied in paper: D. Jur\[CHacek]iukonis and L. \
Lavoura, ",
  FontSize->16],
 StyleBox["Conditions for boundedness from below of a \
\[CapitalDelta](54)-symmetric three-Higgs-doublet model",
  FontSize->16,
  FontSlant->"Italic"],
 StyleBox[", arXiv:xxxx.xxxxx.",
  FontSize->16]
}], "Text",
