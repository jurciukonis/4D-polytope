       RowBox[{"\"\<V1\>\"", ",", "\"\<V4\>\""}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{"\"\<V2\>\"", ",", "\"\<V3\>\""}], "}"}]}], "}"}]}], 
   ";"}]}]], "Input",
