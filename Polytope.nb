Cell["Definition of the parameters", "Text",
 CellChangeTimes->{{3.987243010030796*^9, 
  3.987243020775155*^9}},ExpressionUUID->"477f2542-e5e7-44e6-9d71-\
35e4f5aa3417"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"vars", "=", 
   RowBox[{"{", 
    RowBox[{"x", ",", "y", ",", "q", ",", "t"}], "}"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"dim", "=", 
   RowBox[{"Length", "[", "vars", "]"}]}], ";"}]}], "Input",
 CellChangeTimes->{{3.98724309934984*^9, 3.987243099583785*^9}},
 CellLabel->
  "In[5138]:=",ExpressionUUID->"530b6812-5c8c-4b46-8a85-618b8d5e1527"],

Cell["Inequalities which define the polytope", "Text",
 CellChangeTimes->{{3.987243010030796*^9, 3.987243020775155*^9}, {
  3.987243071860066*^9, 
  3.987243087199873*^9}},ExpressionUUID->"39b3ec83-86b1-4cc3-9c7c-\
b586c72fc610"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"ineqs", "=", 
    RowBox[{"And", "[", 
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{"-", "1"}], "/", "4"}], "<=", "x", "<=", "0"}], ",", 
      RowBox[{"q", "<=", 
       RowBox[{"1", "/", "3"}]}], ",", 
      RowBox[{"y", "<=", "t", "<=", 
       RowBox[{"-", "y"}]}], ",", 
      RowBox[{
       RowBox[{
        RowBox[{"3", " ", "x"}], "+", "y", "+", 
        RowBox[{"3", " ", "q"}]}], ">=", "0"}]}], "]"}]}], ";"}], 
  "\[IndentingNewLine]", "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{
   "These", " ", "are", " ", "the", " ", "equality", " ", "cases", " ", "of", 
    " ", "the", " ", "supporting", " ", 
    RowBox[{"inequalities", ":"}]}], "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"hyperplaneNames", "=", 
   RowBox[{"{", 
    RowBox[{
    "\"\<x = -1/4\>\"", ",", "\"\<x = 0\>\"", ",", "\"\<q = 1/3\>\"", ",", 
     "\"\<t = y\>\"", ",", "\"\<t = -y\>\"", ",", "\"\<3x + y + 3q = 0\>\""}],
     "}"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"hyperplaneNormals", "=", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"1", ",", "0", ",", "0", ",", "0"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"1", ",", "0", ",", "0", ",", "0"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"0", ",", "0", ",", "1", ",", "0"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"0", ",", 
       RowBox[{"-", "1"}], ",", "0", ",", "1"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"0", ",", "1", ",", "0", ",", "1"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"3", ",", "1", ",", "3", ",", "0"}], "}"}]}], "}"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"hyperplaneRHS", "=", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{
      RowBox[{"-", "1"}], "/", "4"}], ",", "0", ",", 
     RowBox[{"1", "/", "3"}], ",", "0", ",", "0", ",", "0"}], "}"}]}], 
  ";"}], "\n", 
 RowBox[{
  RowBox[{"numHyperplanes", "=", 
   RowBox[{"Length", "[", "hyperplaneNames", "]"}]}], ";"}]}], "Input",
 CellChangeTimes->{
  3.987243091227138*^9, {3.98724316572114*^9, 3.987243176672123*^9}, {
   3.987243256654468*^9, 3.9872432837152042`*^9}, {3.987243447868752*^9, 
   3.987243458421207*^9}},
 CellLabel->
  "In[5140]:=",ExpressionUUID->"11419c2f-f022-4144-aaff-897d248bc959"],

Cell["Auxiliary  functions", "Text",
 CellChangeTimes->{{3.987243366717196*^9, 
  3.987243390922818*^9}},ExpressionUUID->"4b94a593-eee0-48ac-8bc3-\
8bee98686d68"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"feasibleQ", "[", "pt_List", "]"}], ":=", 
   RowBox[{"TrueQ", "[", 
    RowBox[{"ineqs", "/.", " ", 
     RowBox[{"Thread", "[", 
      RowBox[{"vars", "->", "pt"}], "]"}]}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"affineDim", "[", "pts_List", "]"}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"p", "=", "pts"}], "}"}], ",", 
     RowBox[{"If", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"Length", "[", "p", "]"}], "<=", "1"}], ",", "0", ",", 
       RowBox[{"MatrixRank", "[", 
        RowBox[{
         RowBox[{"Rest", "[", "p", "]"}], "-", 
         RowBox[{"ConstantArray", "[", 
          RowBox[{
           RowBox[{"First", "[", "p", "]"}], ",", 
           RowBox[{
            RowBox[{"Length", "[", "p", "]"}], "-", "1"}]}], "]"}]}], "]"}]}],
       "]"}]}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"faceDimFromConstraints", "[", "S_List", "]"}], ":=", 
   RowBox[{"dim", "-", 
    RowBox[{"MatrixRank", "[", 
     RowBox[{"hyperplaneNormals", "[", 
      RowBox[{"[", "S", "]"}], "]"}], "]"}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"canonicalSort", "[", "faces_List", "]"}], ":=", 
   RowBox[{"SortBy", "[", 
    RowBox[{
     RowBox[{"DeleteDuplicates", "[", 
      RowBox[{"Sort", "/@", "faces"}], "]"}], ",", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        RowBox[{"Length", "[", "#", "]"}], ",", 
        RowBox[{"ToString", "[", 
         RowBox[{"#", ",", "InputForm"}], "]"}]}], "}"}], "&"}]}], "]"}]}], 
  ";"}]}], "Input",
 CellChangeTimes->{{3.987243400803083*^9, 3.9872434054148684`*^9}},
 CellLabel->
  "In[5145]:=",ExpressionUUID->"4d4f403b-6489-4f63-b006-be0be8282029"],

Cell["Vertices from the inequalities", "Text",
 CellChangeTimes->{{3.987243366717196*^9, 3.987243390922818*^9}, 
   3.98738883552852*^9},ExpressionUUID->"d72a46df-a938-4686-9d85-\
dec080744449"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"candidateVertices", "=", 
   RowBox[{"DeleteDuplicates", "@", 
    RowBox[{"Cases", "[", 
     RowBox[{
      RowBox[{"Subsets", "[", 
       RowBox[{
        RowBox[{"Range", "[", "numHyperplanes", "]"}], ",", 
        RowBox[{"{", "dim", "}"}]}], "]"}], ",", 
      RowBox[{
       RowBox[{"idx_", "/;", 
        RowBox[{
         RowBox[{"MatrixRank", "[", 
          RowBox[{"hyperplaneNormals", "[", 
           RowBox[{"[", "idx", "]"}], "]"}], "]"}], "==", "dim"}]}], ":>", 
       RowBox[{"LinearSolve", "[", 
        RowBox[{
         RowBox[{"hyperplaneNormals", "[", 
          RowBox[{"[", "idx", "]"}], "]"}], ",", 
         RowBox[{"hyperplaneRHS", "[", 
          RowBox[{"[", "idx", "]"}], "]"}]}], "]"}]}]}], "]"}]}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"foundVertices", "=", 
    RowBox[{"Select", "[", 
     RowBox[{"candidateVertices", ",", "feasibleQ"}], "]"}]}], ";"}], 
  "\[IndentingNewLine]", "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{
   "We", " ", "reorder", " ", "vertices", " ", "in", " ", "foundVertices", 
    " ", "to", " ", "prefered", " ", "order"}], 
   "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"preferredOrder", "=", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"0", ",", "0", ",", "0", ",", "0"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"0", ",", "0", ",", 
       RowBox[{"1", "/", "3"}], ",", "0"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{
        RowBox[{"-", "1"}], "/", "4"}], ",", "0", ",", 
       RowBox[{"1", "/", "3"}], ",", "0"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{
        RowBox[{"-", "1"}], "/", "4"}], ",", "0", ",", 
       RowBox[{"1", "/", "4"}], ",", "0"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{
        RowBox[{"-", "1"}], "/", "4"}], ",", 
       RowBox[{
        RowBox[{"-", "1"}], "/", "4"}], ",", 
       RowBox[{"1", "/", "3"}], ",", 
       RowBox[{"1", "/", "4"}]}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"0", ",", 
       RowBox[{"-", "1"}], ",", 
       RowBox[{"1", "/", "3"}], ",", "1"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{
        RowBox[{"-", "1"}], "/", "4"}], ",", 
       RowBox[{
        RowBox[{"-", "1"}], "/", "4"}], ",", 
       RowBox[{"1", "/", "3"}], ",", 
       RowBox[{
        RowBox[{"-", "1"}], "/", "4"}]}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"0", ",", 
       RowBox[{"-", "1"}], ",", 
       RowBox[{"1", "/", "3"}], ",", 
       RowBox[{"-", "1"}]}], "}"}]}], "}"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"orderedVertices", "=", 
   RowBox[{"If", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"Sort", "[", "foundVertices", "]"}], "===", 
      RowBox[{"Sort", "[", "preferredOrder", "]"}]}], ",", "preferredOrder", 
     ",", 
     RowBox[{"Sort", "[", "foundVertices", "]"}]}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"vertexLabels", "=", 
   RowBox[{"Table", "[", 
    RowBox[{
     RowBox[{"\"\<V\>\"", "<>", 
      RowBox[{"ToString", "[", "i", "]"}]}], ",", 
     RowBox[{"{", 
      RowBox[{"i", ",", 
       RowBox[{"Length", "[", "orderedVertices", "]"}]}], "}"}]}], "]"}]}], 
  ";"}], "\n", 
 RowBox[{
  RowBox[{"vertices", "=", 
   RowBox[{"AssociationThread", "[", 
    RowBox[{"vertexLabels", "->", "orderedVertices"}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"activeSet", "[", "label_", "]"}], ":=", 
   RowBox[{"Flatten", "@", 
    RowBox[{"Position", "[", 
     RowBox[{
      RowBox[{"MapThread", "[", 
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{"Dot", "[", 
           RowBox[{"#1", ",", 
            RowBox[{"vertices", "[", "label", "]"}]}], "]"}], "-", "#2"}], 
         "&"}], ",", 
        RowBox[{"{", 
         RowBox[{"hyperplaneNormals", ",", "hyperplaneRHS"}], "}"}]}], "]"}], 
      ",", "0"}], "]"}]}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"commonActive", "[", "face_List", "]"}], ":=", 
   RowBox[{"Intersection", "@@", 
    RowBox[{"(", 
     RowBox[{"activeSet", "/@", "face"}], ")"}]}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"faceVerticesFromConstraints", "[", "S_List", "]"}], ":=", 
   RowBox[{"Select", "[", 
    RowBox[{"vertexLabels", ",", 
     RowBox[{
      RowBox[{"ContainsAll", "[", 
       RowBox[{
        RowBox[{"activeSet", "[", "#", "]"}], ",", "S"}], "]"}], "&"}]}], 
    "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"boundaryEdges", "[", 
    RowBox[{"face_", ",", "edgeList_"}], "]"}], ":=", 
   RowBox[{"Select", "[", 
    RowBox[{"edgeList", ",", 
     RowBox[{
      RowBox[{"ContainsAll", "[", 
       RowBox[{"face", ",", "#"}], "]"}], "&"}]}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"twoFaceType", "[", "face_List", "]"}], ":=", 
   RowBox[{"Switch", "[", 
    RowBox[{
     RowBox[{"Length", "[", "face", "]"}], ",", "3", ",", "\"\<triangle\>\"", 
     ",", "4", ",", "\"\<quadrilateral\>\"", ",", "_", ",", "\"\<other\>\""}],
     "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"facetType", "[", "face_List", "]"}], ":=", 
   RowBox[{"Switch", "[", 
    RowBox[{
     RowBox[{"Length", "[", "face", "]"}], ",", "4", ",", 
     "\"\<tetrahedron\>\"", ",", "6", ",", "\"\<triangular prism\>\"", ",", 
     "_", ",", "\"\<other\>\""}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"allConstraintSets", "=", 
   RowBox[{"Rest", "@", 
    RowBox[{"Subsets", "[", 
     RowBox[{"Range", "[", "numHyperplanes", "]"}], "]"}]}]}], 
  ";"}]}], "Input",
 CellChangeTimes->{{3.9873888385463142`*^9, 3.987388875004365*^9}, {
   3.987388922562522*^9, 3.987388929062592*^9}, {3.9873894135699472`*^9, 
   3.987389467999748*^9}, 3.9873946883250732`*^9},
 CellLabel->
  "In[5149]:=",ExpressionUUID->"7a03df3e-b4d4-44e5-98c1-2c7e92a25ddb"],

Cell["Edges", "Text",
 CellChangeTimes->{{3.987243366717196*^9, 3.987243390922818*^9}, 
   3.987388961512342*^9},ExpressionUUID->"c57ecdad-e150-4e23-947b-\
920387b613b5"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"pairs", "=", 
   RowBox[{"Subsets", "[", 
    RowBox[{"vertexLabels", ",", 
     RowBox[{"{", "2", "}"}]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"edgeQ", "[", "pair_List", "]"}], ":=", 
   RowBox[{
    RowBox[{"faceDimFromConstraints", "[", 
     RowBox[{"commonActive", "[", "pair", "]"}], "]"}], "==", "1"}]}], 
  ";"}], "\n", 
 RowBox[{
  RowBox[{"edgeList", "=", 
   RowBox[{"Select", "[", 
    RowBox[{"pairs", ",", "edgeQ"}], "]"}]}], ";"}]}], "Input",
 CellChangeTimes->{{3.98738896452315*^9, 3.987388966750723*^9}, {
  3.987390371750225*^9, 3.987390374451879*^9}},
 CellLabel->
  "In[5162]:=",ExpressionUUID->"a171774e-ad59-4945-a68c-3b27bae914fd"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
   "We", " ", "reorder", " ", "edges", " ", "to", " ", "prefered", " ", 
    "order"}], "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{"edgeList", "=", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"\"\<V6\>\"", ",", "\"\<V8\>\""}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{"\"\<V1\>\"", ",", "\"\<V6\>\""}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{"\"\<V1\>\"", ",", "\"\<V8\>\""}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{"\"\<V2\>\"", ",", "\"\<V6\>\""}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{"\"\<V2\>\"", ",", "\"\<V8\>\""}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{"\"\<V1\>\"", ",", "\"\<V2\>\""}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{"\"\<V5\>\"", ",", "\"\<V7\>\""}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{"\"\<V4\>\"", ",", "\"\<V5\>\""}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{"\"\<V4\>\"", ",", "\"\<V7\>\""}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{"\"\<V3\>\"", ",", "\"\<V5\>\""}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{"\"\<V3\>\"", ",", "\"\<V7\>\""}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{"\"\<V3\>\"", ",", "\"\<V4\>\""}], "}"}], ",", 
