Cell["Polygonal 2-faces", "Text",
 CellChangeTimes->{{3.987243366717196*^9, 3.987243390922818*^9}, 
   3.987388985380849*^9},ExpressionUUID->"97c65e08-15fc-432e-b47d-\
46d517e1fc0b"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"twoFaces", "=", 
    RowBox[{"canonicalSort", "@", 
     RowBox[{"Select", "[", 
      RowBox[{
       RowBox[{"Cases", "[", 
        RowBox[{"allConstraintSets", ",", 
         RowBox[{
          RowBox[{"S_", "/;", 
           RowBox[{
